            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"NEW-123\",\n  \"name\": \"Nuevo Producto\",\n  \"description\": \"Descripción de prueba\",\n  \"category\": \"RODAMIENTOS\",\n  \"status\": \"AVAILABLE\",\n  \"location\": \"Estante Z\",\n  \"stock\": 10,\n  \"innerDiameter\": \"10mm\",\n  \"outerDiameter\": \"20mm\",\n  \"width\": \"5mm\",\n  \"weight\": \"50g\",\n  \"material\": \"Acero\",\n  \"imageUrl\": \"https://example.com/product.png\"\n}"
            },
